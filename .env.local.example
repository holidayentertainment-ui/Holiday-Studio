# ── Gemini AI ─────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
gemini_API_KEY=your_gemini_api_key_here

# ── Supabase ───────────────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — NEVER expose this publicly, server-side only
# Used by the Stripe webhook to write purchase records (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Stripe ─────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...           # or sk_test_... for test mode

# Get from: dashboard.stripe.com → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Your hosted Stripe Checkout payment link
# Set Success URL to: https://yourdomain.com/?payment=success
# Set Cancel URL to:  https://yourdomain.com/
NEXT_PUBLIC_STRIPE_CHECKOUT_URL=https://buy.stripe.com/...
